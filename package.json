{
  "name": "buyfootball.store",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/generate-sitemap.mjs && node scripts/generate-merchant-feed.mjs",
    "build": "next build",
    "preview": "npx serve out",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "seo:generate": "node scripts/generate-sitemap.mjs && node scripts/generate-merchant-feed.mjs",
    "seo:validate": "node scripts/validate-seo.mjs",
    "seo:validate-sitemap": "node scripts/validate-sitemap.mjs",
    "seo:validate-canonicals": "node scripts/validate-canonicals.mjs",
    "seo:validate-metadata": "node scripts/validate-metadata.mjs",
    "seo:validate-schema": "node scripts/validate-structured-data.mjs",
    "seo:validate-links": "node scripts/check-internal-links.mjs",
    "seo:validate-feed": "node scripts/validate-merchant-feed.mjs",
    "seo:launch-check": "node scripts/check-launch-readiness.mjs",
    "seo:launch-check:deploy": "node scripts/check-launch-readiness.mjs --deployment"
  },
  "dependencies": {
    "lucide-react": "^1.25.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
